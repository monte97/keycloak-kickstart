# Keycloak admin credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme

# Database credentials (used by both keycloak and keycloak-db services)
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=changeme

# Exposed port (default: 8080)
KC_PORT=8080

# How long (seconds) the init container waits for Keycloak to become ready (default: 300)
# KC_HEALTHCHECK_TIMEOUT=300

# Seed-specific variables (referenced in seed.yml via ${VAR} interpolation)
# APP_URL=http://localhost:3000
# ADMIN_PASSWORD=admin
# USER_PASSWORD=user

# SMTP (uncomment if using email verification/password reset)
# SMTP_HOST=smtp.example.com
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SENDER=noreply@example.com

# Webhook secret (uncomment if using HMAC-signed webhooks)
# WEBHOOK_SECRET=your-secret-here
